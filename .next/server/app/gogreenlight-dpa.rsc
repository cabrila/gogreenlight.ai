en":["$","a",null,{"href":"#section-5","className":"hover:text-primary transition-colors","children":"Confidentiality"}]}],["$","li",null,{"children":["$","a",null,{"href":"#section-6","className":"hover:text-primary transition-colors","children":"Security of Processing"}]}],["$","li",null,{"children":["$","a",null,{"href":"#section-7","className":"hover:text-primary transition-colors","children":"Use of Sub-Processors"}]}],["$","li",null,{"children":["$","a",null,{"href":"#section-8","className":"hover:text-primary transition-colors","children":"Transfer of Data to Third Countries or International Organizations"}]}],["$","li",null,{"children":"$L5"}],"$L6","$L7","$L8","$L9","$La","$Lb"]}],"$Lc","$Ld"]}],"$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21"]}]}],null,"$L22"]}],{},null,false]},null,false]},null,false],"$L23",false]],"m":"$undefined","G":["$24",[]],"s":false,"S":true}
