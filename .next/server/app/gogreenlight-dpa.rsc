d:["$","ul",null,{"className":"list-disc list-inside space-y-1 text-sm text-muted-foreground ml-4","children":[["$","li",null,{"children":"Appendix A: Information About the Processing"}],["$","li",null,{"children":["$","$L25",null,{"href":"/dpa-appendix-b","className":"text-primary hover:underline","children":"Appendix B: Authorized Sub-Processors"}]}],["$","li",null,{"children":"Appendix C: Instruction Pertaining to the Use of Personal Data"}],["$","li",null,{"children":"Appendix D: The Parties' Terms of Agreement on Other Subjects"}]]}]
e:["$","section",null,{"id":"section-1","className":"scroll-mt-24","children":[["$","h2",null,{"className":"text-2xl font-bold text-foreground mb-4","children":"1. Introduction"}],["$","div",null,{"className":"text-muted-foreground leading-relaxed space-y-4","children":[["$","p",null,{"children":"This Data Processing Agreement is based on The Danish Data Protection Agency's standard template for Data Processing Agreements. The Danish Data Protection Agency is the independent authority that supervises compliance with the rules on protection of personal data in Denmark."}],["$","p",null,{"children":"This Data Processing Agreement is based on the standard processor agreement that has been adopted by the Danish SA pursuant to Article 28(8) GDPR and aims at helping organizations to meet the requirements of Article 28(3) and (4), given that the contract between controller and processor cannot merely restate the provisions of the GDPR but must further specify them, e.g. with regard to the assistance provided by the processor to the controller."}],["$","p",null,{"children":"The possibility of using SCCs adopted by a Supervisory Authority (SA) does not prevent the parties from adding other clauses or additional safeguards, provided that they do not contradict, directly or indirectly, the adopted clauses or prejudice the fundamental rights or freedoms of the data subjects."}],["$","p",null,{"className":"text-sm italic","children":"Note: As of March 2024, the clause concerning the designation of the controller as a third-party beneficiary in case of the processor's insolvency or legal cessation has been made optional and its wording aligned with the European Commission's 2021 SCCs."}],["$","p",null,{"children":"For the purposes of Article 28(3) of Regulation 2016/679 (the GDPR):"}],["$","p",null,{"children":"the data processor"}],["$","p",null,{"children":"and"}],["$","p",null,{"children":"the data controller"}],["$","p",null,{"children":"each a 'party'; together 'the parties'"}],["$","p",null,{"children":"have agreed on the following Contractual Clauses (the Clauses) in order to meet the requirements of the GDPR and to ensure the protection of the rights of the data subject."}]]}]]}]
f:["$","section",null,{"id":"section-2","className":"scroll-mt-24","children":[["$","h2",null,{"className":"text-2xl font-bold text-foreground mb-4","children":"2. Preamble"}],["$","div",null,{"className":"text-muted-foreground leading-relaxed space-y-4","children":[["$","p",null,{"children":"These Contractual Clauses (the Clauses) set out the rights and obligations of the data controller and the data processor, when processing personal data on behalf of the data controller."}],["$","p",null,{"children":"In the context of providing the GoGreenlight platform – a decision-making and creative asset selection software used for e.g., casting, location, and production approvals in film, TV, theatre, and other creative productions – the data processor will process personal data on behalf of the data controller in accordance with these Clauses."}],["$","ol",null,{"className":"list-decimal list-inside space-y-2 ml-4","children":[["$","li",null,{"children":"The Clauses shall not exempt the data processor from obligations to which the data processor is subject pursuant to the General Data Protection Regulation (the GDPR) or other legislation."}],["$","li",null,{"children":"The Clauses along with appendices shall be retained in writing, including electronically, by both parties."}],["$","li",null,{"children":"Appendix D contains provisions for other activities which are not covered by the Clauses."}],["$","li",null,{"children":"Appendix C contains the data controller's instructions with regards to the processing of personal data, the minimum security measures to be implemented by the data processor and how audits of the data processor and any sub-processors are to be performed."}],["$","li",null,{"children":[["$","$L25",null,{"href":"/dpa-appendix-b","className":"text-primary hover:underline","children":"Appendix B"}]," ","contains the data controller's conditions for the data processor's use of sub-processors and a list of sub-processors authorised by the data controller."]}],["$","li",null,{"children":"Appendix A contains details about the processing of personal data, including the purpose and nature of the processing, type of personal data, categories of data subject and duration of the processing."}],["$","li",null,{"children":"Four appendices are attached to the Clauses and form an integral part of the Clauses."}],["$","li",null,{"children":"The Clauses shall take priority over any similar provisions contained in other agreements between the parties."}],["$","li",null,{"children":"The Clauses have been designed to ensure the parties' compliance with Article 28(3) of Regulation 2016/679 of the European Parliament and of the Council of 27 April 2016 on the protection of natural persons with regard to the processing of personal data and on the free movement of such data and repealing Directive 95/46/EC (General Data Protection Regulation)."}]]}]]}]]}]
10:["$","section",null,{"id":"section-3","className":"scroll-mt-24","children":[["$","h2",null,{"className":"text-2xl font-bold text-foreground mb-4","children":"3. The Rights and Obligations of the Data Controller"}],["$","div",null,{"className":"text-muted-foreground leading-relaxed space-y-4","children":["$","ol",null,{"className":"list-decimal list-inside space-y-2 ml-4","children":[["$","li",null,{"children":"The data controller shall be responsible, among other, for ensuring that the processing of personal data, which the data processor is instructed to perform, has a legal basis."}],["$","li",null,{"children":"The data controller has the right and obligation to make decisions about the purposes and means of the processing of personal data."}],["$","li",null,{"children":"The data controller is responsible for ensuring that the processing of personal data takes place in compliance with the GDPR (see Article 24 GDPR), the applicable EU or Member State* data protection provisions and the Clauses."}]]}]}]]}]
11:["$","section",null,{"id":"section-4","className":"scroll-mt-24","children":[["$","h2",null,{"className":"text-2xl font-bold text-foreground mb-4","children":"4. The Data Processor Acts According to Instructions"}],["$","div",null,{"className":"text-muted-foreground leading-relaxed space-y-4","children":["$","ol",null,{"className":"list-decimal list-inside space-y-2 ml-4","children":[["$","li",null,{"children":"The data processor shall immediately inform the data controller if instructions given by the data controller, in the opinion of the data processor, contravene the GDPR or the applicable EU or Member State data protection provisions."}],["$","li",null,{"children":"The data processor shall process personal data only on documented instructions from the data controller, unless required to do so by Union or Member State law to which the processor is subject. Such instructions shall be specified in appendices A and C. Subsequent instructions can also be given by the data controller throughout the duration of the processing of personal data, but such instructions shall always be documented and kept in writing, including electronically, in connection with the Clauses."}]]}]}]]}]
12:["$","section",null,{"id":"section-5","className":"scroll-mt-24","children":[["$","h2",null,{"className":"text-2xl font-bold text-foreground mb-4","children":"5. Confidentiality"}],["$","div",null,{"className":"text-muted-foreground leading-relaxed space-y-4","children":["$","ol",null,{"className":"list-decimal list-inside space-y-2 ml-4","children":[["$","li",null,{"children":"The data processor shall at the request of the data controller demonstrate that the concerned persons under the data processor's authority are subject to the abovementioned confidentiality."}],["$","li",null,{"children":"The data processor shall only grant access to the personal data being processed on behalf of the data controller to persons under the data processor's authority who have committed themselves to confidentiality or are under an appropriate statutory obligation of confidentiality and only on a need to know basis. The list of persons to whom access has been granted shall be kept under periodic review. On the basis of this review, such access to personal data can be withdrawn, if access is no longer necessary, and personal data shall consequently not be accessible anymore to those persons."}]]}]}]]}]
13:["$","section",null,{"id":"section-6","className":"scroll-mt-24","children":[["$","h2",null,{"className":"text-2xl font-bold text-foreground mb-4","children":"6. Security of Processing"}],["$","div",null,{"className":"text-muted-foreground leading-relaxed space-y-4","children":[["$","p",null,{"children":"Article 32 GDPR stipulates that, taking into account the state of the art, the costs of implementation and the nature, scope, context and purposes of processing as well as the risk of varying likelihood and severity for the rights and freedoms of natural persons, the data controller and data processor shall implement appropriate technical and organisational measures to ensure a level of security appropriate to the risk. The data controller shall evaluate the risks to the rights and freedoms of natural persons inherent in the processing and implement measures to mitigate those risks. Depending on their relevance, the measures may include the following:"}],["$","ol",null,{"className":"list-decimal list-inside space-y-2 ml-4","children":[["$","li",null,{"children":"a process for regularly testing, assessing, and evaluating the effectiveness of technical and organizational measures for ensuring the security of processing."}],["$","li",null,{"children":"the ability to restore the availability and access to personal data in a timely manner in the event of a physical or technical incident;"}],["$","li",null,{"children":"the ability to ensure ongoing confidentiality, integrity, availability, and resilience of processing systems and services;"}],["$","li",null,{"children":"Pseudonymisation and encryption of personal data;"}]]}]]}]]}]
14:["$","section",null,{"id":"section-7","className":"scroll-mt-24","children":[["$","h2",null,{"className":"text-2xl font-bold text-foreground mb-4","children":"7. Use of Sub-Processors"}],["$","div",null,{"className":"text-muted-foreground leading-relaxed space-y-4","children":["$","ol",null,{"className":"list-decimal list-inside space-y-2 ml-4","children":[["$","li",null,{"children":"If the sub-processor does not fulfil his data protection obligations, the data processor shall remain fully liable to the data controller as regards the fulfilment of the obligations of the sub-processor. This does not affect the rights of the data subjects under the GDPR – in particular those foreseen in Articles 79 and 82 GDPR – against the data controller and the data processor, including the sub-processor."}],["$","li",null,{"children":"The data processor shall agree a third-party beneficiary clause with the sub-processor where – in the event of bankruptcy of the data processor – the data controller shall be a third-party beneficiary to the sub-processor agreement and shall have the right to enforce the agreement against the sub-processor engaged by the data processor, e.g. enabling the data controller to instruct the sub-processor to delete or return the personal data."}],["$","li",null,{"children":"A copy of such a sub-processor agreement and subsequent amendments shall – at the data controller's request – be submitted to the data controller, thereby giving the data controller the opportunity to ensure that the same data protection obligations as set out in the Clauses are imposed on the sub-processor. Clauses on business related issues that do not affect the legal data protection content of the sub-processor agreement, shall not require submission to the data controller."}],["$","li",null,{"children":"Where the data processor engages a sub-processor for carrying out specific processing activities on behalf of the data controller, the same data protection obligations as set out in the Clauses shall be imposed on that sub-processor by way of a contract or other legal act under EU or Member State law, in particular providing sufficient guarantees to implement appropriate technical and organisational measures in such a manner that the processing will meet the requirements of the Clauses and the GDPR. The data processor shall therefore be responsible for requiring that the sub-processor at least complies with the obligations to which the data processor is subject pursuant to the Clauses and the GDPR."}],["$","li",null,{"children":["The data processor has the data controller's general authorisation for the engagement of sub-processors. The data processor shall inform in writing the data controller of any intended changes concerning the addition or replacement of sub-processors at least 5 work days in advance, thereby giving the data controller the opportunity to object to such changes prior to the engagement of the concerned sub-processor(s). Longer time periods of prior notice for specific sub-processing services can be provided in"," ",["$","$L25",null,{"href":"/dpa-appendix-b","className":"text-primary hover:underline","children":"Appendix B"}],". The list of sub-processors already authorised by the data controller can be found in"," ",["$","$L25",null,{"href":"/dpa-appendix-b","className":"text-primary hover:underline","children":"Appendix B"}],"."]}],["$","li",null,{"children":"The data processor shall therefore not engage another processor (sub-processor) for the fulfilment of the Clauses without the prior general written authorisation of the data controller."}],"$L26","$L27"]}]}]]}]
15:["$","section",null,{"id":"section-8","className":"scroll-mt-24","children":[["$","h2",null,{"className":"text-2xl font-bold text-foreground mb-4","children":"8. Transfer of Data to Third Countries or International Organizations"}],["$","div",null,{"className":"text-muted-foreground leading-relaxed space-y-4","children":[["$","p",null,{"children":"Without documented instructions from the data controller, the data processor therefore cannot within the framework of the Clauses:"}],["$","ol",null,{"className":"list-decimal list-inside space-y-2 ml-4","children":[["$","li",null,{"children":"have the personal data processed in by the data processor in a third country"}],["$","li",null,{"children":"transfer the processing of personal data to a sub-processor in a third country"}],["$","li",null,{"children":"Transfer personal data to a data controller or a data processor in a third country or in an international organization"}]]}]]}]]}]
16:["$","section",null,{"id":"section-9","className":"scroll-mt-24","children":[["$","h2",null,{"className":"text-2xl font-bold text-foreground mb-4","children":"9. Assistance to the Data Controller"}],["$","div",null,{"className":"text-muted-foreground leading-relaxed space-y-4","children":[["$","p",null,{"children":"Taking into account the nature of the processing, the data processor shall assist the data controller by appropriate technical and organisational measures, insofar as this is possible, in the fulfilment of the data controller's obligations to respond to requests for exercising the data subject's rights laid down in Chapter III GDPR. This entails that the data processor shall, insofar as this is possible, assist the data controller in the data controller's compliance with:"}],["$","ol",null,{"className":"list-decimal list-inside space-y-2 ml-4","children":[["$","li",null,{"children":"the right not to be subject to a decision based solely on automated processing, including profiling"}],["$","li",null,{"children":"the right to object"}],["$","li",null,{"children":"the right to data portability"}],["$","li",null,{"children":"notification obligation regarding rectification or erasure of personal data or restriction of processing"}],["$","li",null,{"children":"the right to restriction of processing"}],["$","li",null,{"children":"the right to erasure ('the right to be forgotten')"}],["$","li",null,{"children":"the right to rectification"}],["$","li",null,{"children":"the right of access by the data subject"}],["$","li",null,{"children":"the right to be informed when personal data have not been obtained from the data subject"}],["$","li",null,{"children":"the right to be informed when collecting personal data from the data subject"}]]}],["$","p",null,{"children":"In addition to the data processor's obligation to assist the data controller pursuant to Clause 6.3., the data processor shall furthermore, taking into account the nature of the processing and the information available to the data processor, assist the data controller in ensuring compliance with:"}],["$","ol",null,{"className":"list-decimal list-inside space-y-2 ml-4","children":[["$","li",null,{"children":"the data controller's obligation to consult the competent supervisory authority, The Danish Data Protection Agency, prior to processing where a data protection impact assessment indicates that the processing would result in a high risk in the absence of measures taken by the data controller to mitigate the risk."}],["$","li",null,{"children":"the data controller's obligation to carry out an assessment of the impact of the envisaged processing operations on the protection of personal data (a data protection impact assessment);"}],["$","li",null,{"children":"the data controller's obligation to without undue delay communicate the personal data breach to the data subject, when the personal data breach is likely to result in a high risk to the rights and freedoms of natural persons;"}],["$","li",null,{"children":"The data controller's obligation to without undue delay and, where feasible, not later than 72 hours after having become aware of it, notify the personal data breach to the competent supervisory authority, unless the personal data breach is unlikely to result in a risk to the rights and freedoms of natural persons;"}]]}]]}]]}]
17:["$","section",null,{"id":"section-10","className":"scroll-mt-24","children":[["$","h2",null,{"className":"text-2xl font-bold text-foreground mb-4","children":"10. Notification of Personal Data Breach"}],["$","div",null,{"className":"text-muted-foreground leading-relaxed space-y-4","children":["$","ol",null,{"className":"list-decimal list-inside space-y-2 ml-4","children":[["$","li",null,{"children":"The parties shall define in Appendix C all the elements to be provided by the data processor when assisting the data controller in the notification of a personal data breach to the competent supervisory authority."}],["$","li",null,{"children":["In accordance with Clause 9(2)(a), the data processor shall assist the data controller in notifying the personal data breach to the competent supervisory authority, meaning that the data processor is required to assist in obtaining the information listed below which, pursuant to Article 33(3)GDPR, shall be stated in the data controller's notification to the competent supervisory authority:",["$","ul",null,{"className":"list-disc list-inside ml-4 mt-2 space-y-1","children":[["$","li",null,{"children":"The nature of the personal data including where possible, the categories and approximate number of data subjects concerned, and the categories and approximate number of personal data records concerned;"}],["$","li",null,{"children":"the likely consequences of the personal data breach;"}],["$","li",null,{"children":"the measures taken or proposed to be taken by the controller to address the personal data breach, including, where appropriate, measures to mitigate its possible adverse effects."}]]}]]}],["$","li",null,{"children":"The data processor's notification to the data controller shall, if possible, take place within 72 hours after the data processor has become aware of the personal data breach to enable the data controller to comply with the data controller's obligation to notify the personal data breach to the competent supervisory authority, cf. Article 33 GDPR."}],["$","li",null,{"children":"In case of any personal data breach, the data processor shall, without undue delay after having become aware of it, notify the data controller of the personal data breach."}],["$","li",null,{"children":"The parties shall define in Appendix C the appropriate technical and organisational measures by which the data processor is required to assist the data controller as well as the scope and the extent of the assistance required. This applies to the obligations foreseen in Clause 9.1. and 9.2."}]]}]}]]}]
18:["$","section",null,{"id":"section-11","className":"scroll-mt-24","children":[["$","h2",null,{"className":"text-2xl font-bold text-foreground mb-4","children":"11. Erasure and Return of Data"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"On termination of the provision of personal data processing services, the data processor shall be under obligation to delete all personal data processed on behalf of the data controller and certify to the data controller that it has done so unless Union or Member State law requires storage of the personal data."}]]}]
19:["$","section",null,{"id":"section-12","className":"scroll-mt-24","children":[["$","h2",null,{"className":"text-2xl font-bold text-foreground mb-4","children":"12. Audit and Inspection"}],["$","div",null,{"className":"text-muted-foreground leading-relaxed space-y-4","children":["$","ol",null,{"className":"list-decimal list-inside space-y-2 ml-4","children":[["$","li",null,{"children":"The data processor shall be required to provide the supervisory authorities, which pursuant to applicable legislation have access to the data controller's and data processor's facilities, or representatives acting on behalf of such supervisory authorities, with access to the data processor's physical facilities on presentation of appropriate identification."}],["$","li",null,{"children":"Procedures applicable to the data controller's audits, including inspections, of the data processor and sub-processors are specified in appendices C.7. and C.8."}],["$","li",null,{"children":"The data processor shall make available to the data controller all information necessary to demonstrate compliance with the obligations laid down in Article 28 and the Clauses and allow for and contribute to audits, including inspections, conducted by the data controller or another auditor mandated by the data controller."}]]}]}]]}]
1a:["$","section",null,{"id":"section-13","className":"scroll-mt-24","children":[["$","h2",null,{"className":"text-2xl font-bold text-foreground mb-4","children":"13. The Parties' Agreement on Other Terms"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"The parties may agree other clauses concerning the provision of the personal data processing service specifying e.g. liability, as long as they do not contradict directly or indirectly the Clauses or prejudice the fundamental rights or freedoms of the data subject and the protection afforded by the GDPR."}]]}]
1b:["$","section",null,{"id":"section-14","className":"scroll-mt-24","children":[["$","h2",null,{"className":"text-2xl font-bold text-foreground mb-4","children":"14. Commencement and Termination"}],["$","div",null,{"className":"text-muted-foreground leading-relaxed space-y-4","children":["$","ol",null,{"className":"list-decimal list-inside space-y-2 ml-4","children":[["$","li",null,{"children":"Signature: [Parties signatures]"}],["$","li",null,{"children":"If the provision of personal data processing services is terminated, and the personal data is deleted or returned to the data controller pursuant to Clause 11.1. and Appendix C.4., the Clauses may be terminated by written notice by either party."}],["$","li",null,{"children":"The Clauses shall apply for the duration of the provision of personal data processing services. For the duration of the provision of personal data processing services, the Clauses cannot be terminated unless other Clauses governing the provision of personal data processing services have been agreed between the parties."}],["$","li",null,{"children":"Both parties shall be entitled to require the Clauses renegotiated if changes to the law or inexpediency of the Clauses should give rise to such renegotiation."}],["$","li",null,{"children":"The Clauses shall become effective on the date of both parties' signature."}]]}]}]]}]
1c:["$","section",null,{"id":"section-15","className":"scroll-mt-24","children":[["$","h2",null,{"className":"text-2xl font-bold text-foreground mb-4","children":"15. Data Controller and Data Processor Contact/Contact Points"}],["$","div",null,{"className":"text-muted-foreground leading-relaxed space-y-4","children":["$","ol",null,{"className":"list-decimal list-inside space-y-2 ml-4","children":[["$","li",null,{"children":"The parties shall be under obligation continuously to inform each other of changes to contacts/contact points."}],["$","li",null,{"children":"The parties may contact each other using the following contacts/contact points: [Name, mail etc.]"}]]}]}]]}]
1d:["$","section",null,{"className":"pt-8 border-t border-border","children":[["$","h2",null,{"className":"text-2xl font-bold text-foreground mb-4","children":"Appendix A: Information about the Processing"}],["$","p",null,{"className":"text-sm text-muted-foreground mb-4 italic","children":"This Annex forms part of the Data Processing Agreement between the Data Controller and GoGreenlight (the Data Processor)."}],["$","div",null,{"className":"text-muted-foreground leading-relaxed space-y-6","children":[["$","div",null,{"children":[["$","h3",null,{"className":"text-lg font-semibold text-foreground mb-2","children":"1. Subject-matter and purpose of the processing"}],["$","p",null,{"children":"The Data Processor shall process personal data on behalf of the Data Controller for the purpose of providing access to the GoGreenlight platform. The platform supports casting and production management in creative industries (including film, TV, theatre, and related sectors) by enabling project teams to manage roles, creative asset selection (e.g. actors, locations, and props), and associated metadata."}]]}],["$","div",null,{"children":[["$","h3",null,{"className":"text-lg font-semibold text-foreground mb-2","children":"2. Categories of data subjects"}],["$","p",null,{"children":"The processing concerns the following categories of data subjects:"}],["$","ul",null,{"className":"list-disc list-inside ml-4 space-y-1","children":[["$","li",null,{"children":"Actors and other casting candidates (e.g. extras)"}],["$","li",null,{"children":"Creative and technical personnel involved in productions (e.g., directors, producers, make-up artists)"}],["$","li",null,{"children":"Employees or collaborators of the Data Controller with access to the platform"}],["$","li",null,{"children":"Other individuals whose data may be uploaded in connection with a production project"}]]}]]}],["$","div",null,{"children":[["$","h3",null,{"className":"text-lg font-semibold text-foreground mb-2","children":"3. Categories of personal data"}],["$","p",null,{"children":"The processing includes the following categories of personal data:"}],["$","ul",null,{"className":"list-disc list-inside ml-4 space-y-1","children":[["$","li",null,{"children":"Identification data (e.g., name, email address, phone number)"}],["$","li",null,{"children":"Role-related data (e.g., audition materials, CVs, visual and audio recordings, annotations)"}],["$","li",null,{"children":"Internal project metadata (e.g., casting status, selection history, project assignments)"}],["$","li",null,{"children":"Technical data (e.g., user ID, login time, user activity logs)"}],["$","li",null,{"children":"Communication records where applicable"}]]}]]}],["$","div",null,{"children":[["$","h3",null,{"className":"text-lg font-semibold text-foreground mb-2","children":"4. Nature of the processing"}],["$","p",null,{"children":"The personal data will be subject to the following processing activities:"}],["$","ul",null,{"className":"list-disc list-inside ml-4 space-y-1","children":[["$","li",null,{"children":"Collection, storage, and retrieval"}],["$","li",null,{"children":"Structuring and organizing"}],["$","li",null,{"children":"Access and sharing between authorized users"}],["$","li",null,{"children":"Synchronization between local and central systems"}],["$","li",null,{"children":"Erasure upon request or contract termination"}]]}]]}],["$","div",null,{"children":[["$","h3",null,{"className":"text-lg font-semibold text-foreground mb-2","children":"5. Duration of the processing"}],["$","p",null,{"children":"Personal data will be processed for the duration of the agreement between the parties. Upon termination, the data shall be deleted or returned according to the instructions of the Data Controller."}]]}],["$","div",null,{"children":[["$","h3",null,{"className":"text-lg font-semibold text-foreground mb-2","children":"6. Processing location"}],"$L28"]}]]}]]}]
1e:["$","section",null,{"className":"pt-8 border-t border-border","children":[["$","h2",null,{"className":"text-2xl font-bold text-foreground mb-4","children":"Appendix B: Authorized Sub-Processors"}],["$","div",null,{"className":"text-muted-foreground leading-relaxed space-y-4","children":[["$","h3",null,{"className":"text-lg font-semibold text-foreground mb-2","children":"B1: Approved sub-processors"}],["$","p",null,{"children":"On commencement of the Clauses, the data controller authorises the engagement of the following sub-processors, available on this webpage:"}],["$","p",null,{"children":["$","$L25",null,{"href":"/dpa-appendix-b","className":"text-primary hover:underline","children":"View Sub-Processor List (Appendix B)"}]}],["$","p",null,{"children":"The data controller shall on the commencement of the Clauses authorise the use of the sub-processors listed in the document available above for the processing described for that party. The data processor shall not be entitled – without the data controller's general written authorisation – to engage a sub-processor for a 'different' processing than the one which has been agreed upon or have another sub-processor perform the described processing."}]]}]]}]
1f:["$","section",null,{"className":"pt-8 border-t border-border","children":[["$","h2",null,{"className":"text-2xl font-bold text-foreground mb-4","children":"Appendix C: Instruction Pertaining to the Use of Personal Data"}],["$","p",null,{"className":"text-sm text-muted-foreground mb-4 italic","children":"Annex C: Description of Security Measures"}],["$","p",null,{"className":"text-sm text-muted-foreground mb-4 italic","children":"This Annex forms part of the Data Processing Agreement between the Data Controller and GoGreenlight (the Data Processor)."}],["$","div",null,{"className":"text-muted-foreground leading-relaxed space-y-6","children":[["$","p",null,{"children":"The Data Processor shall implement the following appropriate technical and organizational security measures, as required under Article 32 of the GDPR, to ensure a level of security appropriate to the risk:"}],["$","div",null,{"children":[["$","h3",null,{"className":"text-lg font-semibold text-foreground mb-2","children":"1. Access control"}],["$","ul",null,{"className":"list-disc list-inside ml-4 space-y-1","children":[["$","li",null,{"children":"Unique user authentication for each platform user"}],["$","li",null,{"children":"Role-based access to limit permissions by function (e.g., caster, director, production)"}],["$","li",null,{"children":"Two-factor authentication for administrator accounts"}],["$","li",null,{"children":"Automatic session timeout and inactivity logout"}]]}]]}],["$","div",null,{"children":[["$","h3",null,{"className":"text-lg font-semibold text-foreground mb-2","children":"2. Data encryption"}],["$","ul",null,{"className":"list-disc list-inside ml-4 space-y-1","children":[["$","li",null,{"children":"Encryption of data in transit using HTTPS/TLS 1.2 or higher"}],["$","li",null,{"children":"Encryption of stored data on secure servers (e.g., at rest using AES-256)"}]]}]]}],["$","div",null,{"children":[["$","h3",null,{"className":"text-lg font-semibold text-foreground mb-2","children":"3. Data integrity and system resilience"}],["$","ul",null,{"className":"list-disc list-inside ml-4 space-y-1","children":[["$","li",null,{"children":"Regular data backups with geographically redundant storage"}],["$","li",null,{"children":"Load-balanced infrastructure for high availability"}],["$","li",null,{"children":"Automated monitoring and alerts for critical system operations"}],["$","li",null,{"children":"Version control and audit trails for data modification"}]]}]]}],["$","div",null,{"children":[["$","h3",null,{"className":"text-lg font-semibold text-foreground mb-2","children":"4. Physical security"}],["$","ul",null,{"className":"list-disc list-inside ml-4 space-y-1","children":[["$","li",null,{"children":"Data centers certified under ISO 27001 or equivalent security standards"}],["$","li",null,{"children":"Restricted physical access to server locations"}],["$","li",null,{"children":"Cloud infrastructure hosted with established providers (e.g., Google Cloud Platform)"}]]}]]}],["$","div",null,{"children":[["$","h3",null,{"className":"text-lg font-semibold text-foreground mb-2","children":"5. Internal policies and training"}],["$","ul",null,{"className":"list-disc list-inside ml-4 space-y-1","children":[["$","li",null,{"children":"Staff training on data protection and secure development"}],["$","li",null,{"children":"Internal data processing and incident response policies"}],["$","li",null,{"children":"Access to production systems limited to authorized personnel only"}]]}]]}],["$","div",null,{"children":[["$","h3",null,{"className":"text-lg font-semibold text-foreground mb-2","children":"6. Incident management"}],["$","ul",null,{"className":"list-disc list-inside ml-4 space-y-1","children":[["$","li",null,{"children":"Procedures for detection, investigation, and reporting of personal data breaches"}],["$","li",null,{"children":"Prompt notification to the Data Controller in accordance with the DPA"}],["$","li",null,{"children":"Logging and documentation of incidents"}]]}]]}],"$L29","$L2a"]}]]}]
